---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Maps | ${SITE_TITLE}`} description="Beautiful Maps" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Maps</h1>
			<p>A collection of beautiful maps I made.</p>

			<div class="maps-grid">
				<!-- Maps will be added here -->
				<p class="coming-soon">More maps coming soon...</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.maps-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 2rem;
		margin-top: 2rem;
	}

	.map-item {
		border: 1px solid var(--color-border);
		border-radius: 12px;
		overflow: hidden;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.map-item:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
	}

	.map-item img {
		width: 100%;
		height: 200px;
		object-fit: cover;
	}

	.map-info {
		padding: 1rem;
	}

	.map-title {
		font-weight: 600;
		margin-bottom: 0.5rem;
	}

	.map-description {
		font-size: 0.9rem;
		color: var(--color-text-muted);
	}

	.coming-soon {
		grid-column: 1 / -1;
		text-align: center;
		color: var(--color-text-muted);
		padding: 4rem 0;
	}
</style>
